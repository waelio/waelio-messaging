# MongoDB Connection String
# Copy this file to a new file named .env and replace the placeholder with your actual connection string from MongoDB Atlas.

MONGO_URI="mongodb+srv://<user>:<password>@<your-cluster-url>/messagingApp?retryWrites=true&w=majority"

# Peace2074 Nitro webhook — forward every message for Web Push delivery to offline users
PEACE2074_WEBHOOK_URL="https://peace2074.com/api/webhooks/message"
PEACE2074_WEBHOOK_SECRET=""